#!/bin/bash

if [[ -z $1 ]]; then
  dns=$(gum choose --height 5 --header "Select DNS provider" Cloudflare DHCP Custom)
else
  dns=$1
fi

case "$dns" in
Cloudflare)
  sudo tee /etc/systemd/resolved.conf >/dev/null <<'EOF'
[Resolve]
DNS=1.1.1.1#cloudflare-dns.com 1.0.0.1#cloudflare-dns.com
FallbackDNS=9.9.9.9 149.112.112.112
DNSOverTLS=opportunistic
EOF
  
  # If using systemd-networkd, prevent interfaces from overriding DNS
  if systemctl is-active --quiet systemd-networkd; then
    for file in /etc/systemd/network/*.network; do
      [[ -f "$file" ]] || continue
      if ! grep -q "^\[DHCPv4\]" "$file"; then continue; fi
      if ! sed -n '/^\[DHCPv4\]/,/^\[/p' "$file" | grep -q "^UseDNS="; then
        sudo sed -i '/^\[DHCPv4\]/a UseDNS=no' "$file"
      fi
      if grep -q "^\[IPv6AcceptRA\]" "$file" && ! sed -n '/^\[IPv6AcceptRA\]/,/^\[/p' "$file" | grep -q "^UseDNS="; then
        sudo sed -i '/^\[IPv6AcceptRA\]/a UseDNS=no' "$file"
      fi
    done
  fi

  # Restart only what’s active
  systemctl is-active --quiet systemd-resolved && sudo systemctl restart systemd-resolved
  systemctl is-active --quiet systemd-networkd && sudo systemctl restart systemd-networkd
  ;;

DHCP)
  sudo tee /etc/systemd/resolved.conf >/dev/null <<'EOF'
[Resolve]
DNSOverTLS=no
EOF
  
  # Allow network interfaces to use DHCP DNS (only if using systemd-networkd)
  if systemctl is-active --quiet systemd-networkd; then
    for file in /etc/systemd/network/*.network; do
      [[ -f "$file" ]] || continue
      sudo sed -i '/^UseDNS=no/d' "$file"
    done
  fi

  systemctl is-active --quiet systemd-resolved && sudo systemctl restart systemd-resolved
  systemctl is-active --quiet systemd-networkd && sudo systemctl restart systemd-networkd
  ;;

Custom)
  echo "Enter your DNS servers (space-separated, e.g. '192.168.1.1 1.1.1.1'):"
  read -r dns_servers

  if [[ -z "$dns_servers" ]]; then
    echo "Error: No DNS servers provided."
    exit 1
  fi

  sudo tee /etc/systemd/resolved.conf >/dev/null <<EOF
[Resolve]
DNS=$dns_servers
FallbackDNS=9.9.9.9 149.112.112.112
EOF
  
  # If using systemd-networkd, prevent interfaces from overriding DNS
  if systemctl is-active --quiet systemd-networkd; then
    for file in /etc/systemd/network/*.network; do
      [[ -f "$file" ]] || continue
      if ! grep -q "^\[DHCPv4\]" "$file"; then continue; fi
      if ! sed -n '/^\[DHCPv4\]/,/^\[/p' "$file" | grep -q "^UseDNS="; then
        sudo sed -i '/^\[DHCPv4\]/a UseDNS=no' "$file"
      fi
      if grep -q "^\[IPv6AcceptRA\]" "$file" && ! sed -n '/^\[IPv6AcceptRA\]/,/^\[/p' "$file" | grep -q "^UseDNS="; then
        sudo sed -i '/^\[IPv6AcceptRA\]/a UseDNS=no' "$file"
      fi
    done
  fi

  systemctl is-active --quiet systemd-resolved && sudo systemctl restart systemd-resolved
  systemctl is-active --quiet systemd-networkd && sudo systemctl restart systemd-networkd

  ;;
esac
