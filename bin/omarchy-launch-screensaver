#!/bin/bash

# Exit early if we don't have the tte show
if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensaver is already running (tte is active)
pgrep -x tte >/dev/null && exit 0

# Allow screensaver to be turned off but also force started
if [[ -f ~/.local/state/omarchy/toggles/screensaver-off ]] && [[ $1 != "force" ]]; then
  exit 1
fi

focused=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')

title_prefix='printf "\e]0;Screensaver\a"; '

for m in $(hyprctl monitors -j | jq -r '.[] | .name'); do
  hyprctl dispatch focusmonitor "$m"

  if command -v alacritty >/dev/null; then
    hyprctl dispatch exec -- \
      alacritty --class Screensaver --title=Screensaver \
      --config-file ~/.local/share/omarchy/default/alacritty/screensaver.toml \
      -e bash -lc "${title_prefix}omarchy-cmd-screensaver"
  elif command -v kitty >/dev/null; then
    hyprctl dispatch exec -- \
      kitty --class Screensaver -T Screensaver \
      -e bash -lc "${title_prefix}omarchy-cmd-screensaver"
  else
    hyprctl dispatch exec -- \
      "${TERMINAL:-alacritty}" -e bash -lc "${title_prefix}omarchy-cmd-screensaver"
  fi
done

hyprctl dispatch focusmonitor "$focused"
