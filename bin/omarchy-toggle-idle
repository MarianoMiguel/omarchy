#!/bin/bash

STATE_FILE="$HOME/.local/state/omarchy/toggles/idle-disabled"

mkdir -p "$(dirname "$STATE_FILE")"

if [[ -f "$STATE_FILE" ]]; then
  rm -f "$STATE_FILE"
  notify-send "Now locking/sleeping on idle"
else
  touch "$STATE_FILE"
  notify-send "Stop locking/sleeping on idle"
fi

# Ensure hypridle is running so changes take effect
if ! pgrep -x hypridle >/dev/null; then
  uwsm app -- hypridle >/dev/null 2>&1 &
fi
